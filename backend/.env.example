# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection URL.
# Docker: overridden automatically by docker-compose.yml — no change needed.
# Local dev: point to your local Postgres instance.
DATABASE_URL=postgresql://pp_user:pp_password@localhost:5432/elite_powerplay

# Password for the PostgreSQL user (used by docker-compose.yml).
POSTGRES_PASSWORD=pp_password

# ── Security ──────────────────────────────────────────────────────────────────
# Random secret used to sign JWTs — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret

# ── AI Provider ───────────────────────────────────────────────────────────────
# Whether to call the LLM for recommendation summaries: true | false
LLM_ENABLED=false

# Supported values: openai | custom
AI_PROVIDER=openai

# API key for the selected provider
AI_API_KEY=your-api-key-here

# OpenAI model name (AI_PROVIDER=openai)
# OPENAI_MODEL=gpt-4o

# Custom OpenAI-compatible endpoint (AI_PROVIDER=custom)
# AI_BASE_URL=https://your-server:port/api/v1
# AI_MODEL=your-model-name

# Max tokens the LLM may generate per recommendation summary (default: 512)
# AI_MAX_TOKENS=512

# ── Ingestion Schedule ────────────────────────────────────────────────────────
# How often to re-run the Spansh bulk ingest (hours; default: 24)
SPANSH_INGEST_INTERVAL_HOURS=24

# How often to re-run the EDSM PP sync (hours; default: 6)
EDSM_SYNC_INTERVAL_HOURS=6
